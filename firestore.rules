rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Allow public read access to file access history
    match /fileAccessHistory/{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // User management rules
    match /users/{userId} {
      // Allow read access to authenticated users
      allow read: if request.auth != null;
      
      // Allow write access only to admin users
      allow write: if request.auth != null && 
        request.auth.token.email == "admin@kayodefilani.com";
    }

    // Allow authenticated users to read and write all other documents
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}

